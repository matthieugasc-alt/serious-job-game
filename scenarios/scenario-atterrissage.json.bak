  "initial_events": [
    {
      "event_id": "romain_initial_call",
      "type": "phone_call",
      "actor": "romain",
      "content": "Eh, j'ai un message de Claudia Vargas sur WhatsApp, la cheffe de la d\u00e9l\u00e9gation p\u00e9ruvienne. Elle m'a \u00e9crit depuis Madrid mais c'est en espagnol, je comprends rien. \u00c7a a l'air urgent vu les points d'exclamation. Je te transf\u00e8re."
    },
    {
      "event_id": "whatsapp_claudia",
      "type": "whatsapp_message",
      "actor": "claudia",
      "language": "es",
      "content": "Romain, tenemos un problema. En el mostrador de facturaci\u00f3n en Madrid, la aerol\u00ednea nos inform\u00f3 que la visa Schengen de nuestro colega Jorge Huam\u00e1n Quispe (ingeniero hidr\u00e1ulico del Gobierno Regional de Arequipa) vence hoy a medianoche. La aerol\u00ednea acept\u00f3 embarcarlo, pero nos advirti\u00f3 que la polic\u00eda de fronteras en Burdeos podr\u00eda rechazarlo porque la fecha de salida del territorio (domingo 12 de abril) supera la validez de su visa. Los otros dos pasaportes est\u00e1n en regla. \u00bfQu\u00e9 hacemos? Aterrizamos en 1h40."
    }
  ],

  "phases": [
    {
      "phase_id": "phase_1_comprehension",
      "title": "Compr\u00e9hension",
      "duration_target_min": 3,
      "objective": "Comprendre le message en espagnol et transmettre l'information essentielle \u00e0 Romain",

      "player_input": {
        "type": "free_text",
        "prompt": "Romain attend que tu lui expliques ce que dit le message."
      },

      "agent_behavior": {
        "actor": "romain",
        "style": "Dans l'attente. Ne comprend pas l'espagnol. Pose des questions courtes, pressantes.",
        "response_rules": [
          {
            "condition": "player_delays",
            "line": "Alors ? C'est grave ou pas ? Moi je dois partir \u00e0 l'a\u00e9roport dans 45 minutes\u2026"
          },
          {
            "condition": "player_says_no_spanish",
            "line": "Moi non plus ! Essaie avec un traducteur en ligne, on n'a pas le temps de chercher quelqu'un."
          },
          {
            "condition": "summary_incomplete_or_wrong",
            "line": "Attends, je comprends pas bien. C'est un probl\u00e8me de billet d'avion ou de visa ? C'est quoi exactement le souci ?"
          },
          {
            "condition": "summary_correct",
            "line": "Attends, son visa expire aujourd'hui ?! Mais la mission c'est jusqu'\u00e0 dimanche ! C'est pas possible, on avait tout envoy\u00e9 \u00e0 l'ambassade\u2026"
          }
        ]
      },

      "scoring": {
        "max_score": 5,
        "criteria": [
          {
            "criterion_id": "identified_visa_expiry",
            "description": "Le visa de Jorge Huam\u00e1n Quispe expire aujourd'hui (7 avril)",
            "points": 1,
            "sets_flag": "identified_visa_expiry"
          },
          {
            "criterion_id": "identified_mission_date_mismatch",
            "description": "La mission dure jusqu'au 12 avril, au-del\u00e0 de la validit\u00e9 du visa",
            "points": 1,
            "sets_flag": "identified_mission_date_mismatch"
          },
          {
            "criterion_id": "identified_airline_boarding",
            "description": "La compagnie l'a laiss\u00e9 embarquer malgr\u00e9 tout",
            "points": 1,
            "sets_flag": "identified_airline_boarding"
          },
          {
            "criterion_id": "identified_border_risk",
            "description": "Le risque concret : refoulement par la PAF \u00e0 Bordeaux",
            "points": 1,
            "sets_flag": "identified_border_risk"
          },
          {
            "criterion_id": "identified_others_ok",
            "description": "Les deux autres membres de la d\u00e9l\u00e9gation sont en r\u00e8gle",
            "points": 1,
            "sets_flag": "identified_others_ok"
          }
        ],
        "thresholds": [
          { "range": [5, 5], "sets_adaptive_mode": "autonomy", "label": "Compr\u00e9hension compl\u00e8te" },
          { "range": [3, 4], "sets_adaptive_mode": "standard", "label": "Compr\u00e9hension partielle" },
          { "range": [0, 2], "sets_adaptive_mode": "guided",   "label": "Compr\u00e9hension faible" }
        ]
      },

      "completion_rule": {
        "type": "minimum_key_facts",
        "minimum": 3,
        "or_max_exchanges": 5
      },
      "next_phase": "phase_2_strategy"
    },

    {
      "phase_id": "phase_2_strategy",
      "title": "Strat\u00e9gie",
      "duration_target_min": 5,
      "objective": "Proposer un plan d'action cr\u00e9dible. C'est le joueur qui doit amener l'id\u00e9e de contacter la bonne autorit\u00e9.",

      "player_input": {
        "type": "free_text",
        "prompt": "Qu'est-ce que tu proposes de faire maintenant ?"
      },

      "agent_behavior_by_mode": {
        "autonomy": {
          "actor": "romain",
          "style": "Fait confiance au joueur et se met en retrait. Il valide mais ne guide pas.",
          "response_rules": [
            {
              "condition": "player_proposes_consulate_madrid",
              "line": "Si tu penses que c'est la bonne piste, vas-y. Tu as besoin de quoi de mon c\u00f4t\u00e9 ?"
            },
            {
              "condition": "player_proposes_wrong_track",
              "line": "Hmm\u2026 tu es s\u00fbr\u00b7e ? Moi je sais pas trop, c'est toi qui as compris le message. Fais comme tu le sens, mais fais vite."
            },
            {
              "condition": "player_proposes_nothing",
              "line": "C'est toi qui as la vision du probl\u00e8me, moi j'ai pas compris le message. Qu'est-ce que tu proposes ?"
            }
          ]
        },
        "standard": {
          "actor": "romain",
          "style": "Coop\u00e8re activement, r\u00e9agit aux id\u00e9es, recadre si n\u00e9cessaire.",
          "response_rules": [
            {
              "condition": "player_proposes_call_nathalie",
              "line": "J'ai essay\u00e9, elle d\u00e9croche pas. Elle est en r\u00e9union au Minist\u00e8re jusqu'\u00e0 11h, tu sais comment c'est\u2026 On peut pas attendre."
            },
            {
              "condition": "player_proposes_contact_lima",
              "line": "Lima ? Mais ils sont d\u00e9j\u00e0 en route pour Bordeaux, c'est trop tard pour Lima. Et avec le d\u00e9calage horaire il est genre 3h du matin l\u00e0-bas."
            },
            {
              "condition": "player_proposes_consulate_madrid",
              "line": "Oui, pas b\u00eate ! C'est leur derni\u00e8re escale. Il me semble qu'on a l'email du service des visas quelque part dans le dossier."
            },
            {
              "condition": "player_proposes_call_paf_only",
              "line": "On peut essayer, mais la PAF va nous demander un document officiel, ils vont pas nous croire sur parole. Il faudrait un truc \u00e9crit d'une autorit\u00e9 comp\u00e9tente."
            },
            {
              "condition": "player_has_full_strategy",
              "line": "Ok, \u00e7a me para\u00eet bien. Toi tu r\u00e9diges, moi je retrouve le num\u00e9ro de la PAF au cas o\u00f9. On a la lettre d'invitation du Pr\u00e9sident dans le dossier, \u00e7a peut servir."
            }
          ]
        },
        "guided": {
          "actor": "romain",
          "style": "Essaie d'aider mais n'a pas beaucoup plus de recul. R\u00e9fl\u00e9chit \u00e0 voix haute de mani\u00e8re d\u00e9sordonn\u00e9e. Ne donne JAMAIS le plan complet. L\u00e2che des indices flous que le joueur doit assembler.",
          "response_rules": [
            {
              "condition": "phase_entry",
              "line": "Bon \u00e9coute, j'ai rappel\u00e9 Claudia, j'ai compris un mot sur trois mais je crois que c'est un truc de visa qui expire. Enfin je suis pas s\u00fbr. Toi t'as compris quoi exactement ?"
            },
            {
              "condition": "player_confirms_visa_problem",
              "line": "Ok\u2026 donc il va se faire bloquer \u00e0 l'a\u00e9roport, c'est \u00e7a ? Merde. Il faut qu'on pr\u00e9vienne quelqu'un, non ? Mais qui ? Nathalie r\u00e9pond pas\u2026"
            },
            {
              "condition": "player_proposes_nothing",
              "line": "Faut qu'on contacte une autorit\u00e9, un consulat, une ambassade, je sais pas\u2026 T'as pas un annuaire ou un truc dans le dossier ?"
            },
            {
              "condition": "player_proposes_any_track",
              "line": "Peut-\u00eatre, je sais pas. Essaie, on verra bien. De toute fa\u00e7on on a pas 50 options."
            },
            {
              "condition": "player_fully_blocked_after_multiple_exchanges",
              "line": "\u00c9coute, moi le seul truc que je sais c'est qu'ils sont en escale \u00e0 Madrid. Est-ce qu'il y a pas un consulat fran\u00e7ais l\u00e0-bas \u00e0 qui on pourrait \u00e9crire ? Je dis \u00e7a, je dis rien\u2026"
            }
          ]
        }
      },

      "scoring": {
        "max_score": 5,
        "criteria": [
          {
            "criterion_id": "named_consulate_madrid",
            "description": "Identifie le consulat de France \u00e0 Madrid comme interlocuteur pertinent",
            "points": 1,
            "sets_flag": "named_consulate_madrid"
          },
          {
            "criterion_id": "chose_formal_email",
            "description": "Propose d'\u00e9crire un courriel formel (pas seulement un appel)",
            "points": 1,
            "sets_flag": "chose_formal_email"
          },
          {
            "criterion_id": "copied_paf",
            "description": "Pense \u00e0 mettre la PAF en copie",
            "points": 1,
            "sets_flag": "copied_paf"
          },
          {
            "criterion_id": "parallel_action",
            "description": "Envisage une action parall\u00e8le (appel PAF + mail consulat)",
            "points": 1,
            "sets_flag": "parallel_action_suggested"
          },
          {
            "criterion_id": "strategy_without_help",
            "description": "Arrive \u00e0 la strat\u00e9gie sans aide directionnelle forte de Romain",
            "points": 1,
            "sets_flag": "strategy_found_without_help",
            "note": "Attribu\u00e9 si le joueur identifie le consulat de Madrid avant que Romain ne le mentionne, quel que soit le mode adaptatif"
          }
        ]
      },

      "completion_rule": {
        "type": "required_flag",
        "flag": "named_consulate_madrid",
        "or_max_exchanges": 8
      },
      "next_phase": "phase_3_execution"
    },

    {
      "phase_id": "phase_3_execution",
      "title": "Ex\u00e9cution",
      "duration_target_min": 10,
      "objective": "Structurer son approche puis r\u00e9diger le courriel au consulat",

      "subphases": [
        {
          "subphase_id": "phase_3a_method",
          "title": "M\u00e9thode",
          "duration_target_min": 2,

          "trigger_line": {
            "actor": "romain",
            "content": "Ok, avant que tu te lances, dis-moi vite : tu \u00e9cris \u00e0 qui exactement, tu mets qui en copie, et tu joins quoi ? Que je sois s\u00fbr qu'on est align\u00e9s avant que je parte chercher les num\u00e9ros de la PAF."
          },

          "player_input": {
            "type": "free_text",
            "prompt": "D\u00e9cris ton plan d'envoi : destinataire, copie, pi\u00e8ces jointes, grandes lignes du message."
          },

          "expected_elements": [
            { "element": "destinataire", "expected": "Service des visas, Consulat g\u00e9n\u00e9ral de France \u00e0 Madrid" },
            { "element": "copie", "expected": "PAF Bordeaux-M\u00e9rignac" },
            { "element": "pj", "expected": "Lettre d'invitation, copie visa/passeport Jorge, programme, vol retour" },
            { "element": "plan_message", "expected": "Contexte \u2192 probl\u00e8me \u2192 demande \u2192 disponibilit\u00e9" }
          ],

          "agent_feedback_rules": [
            {
              "if_missing": "copie_paf",
              "actor": "romain",
              "line": "Et la PAF de Bordeaux, tu les mets pas en copie ? C'est quand m\u00eame eux qui vont d\u00e9cider si Jorge passe ou pas\u2026"
            },
