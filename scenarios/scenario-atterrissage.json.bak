      "availability": "Dans l'avion, visa probl\u00e9matique"
    },
    {
      "actor_id": "consulat_madrid",
      "name": "Consulat g\u00e9n\u00e9ral de France \u00e0 Madrid",
      "role": "Service des visas",
      "personality": "Formel, prudent, bureaucratique. Utilise le conditionnel. Ne s'engage pas clairement.",
      "interaction_modes": ["email"],
      "controlled_by": "system"
    },
    {
      "actor_id": "paf_bordeaux",
      "name": "PAF Bordeaux-M\u00e9rignac",
