  "constraints": {
    "time_pressure": true,
    "hierarchy_limit": "Le joueur n'est pas habilit\u00e9 \u00e0 engager officiellement la R\u00e9gion. Il mentionne que sa responsable confirmera d\u00e8s 11h.",
    "diplomatic_tone_required": true,
    "uncertainty": "Le joueur ne sait pas si le consulat va r\u00e9pondre, ni si la PAF acceptera. Le consulat n'est pas responsable de l'erreur.",
    "input_language": "es",
    "output_language": "fr"
  },

