---
title: Serious Job Game — Architecture Complète V1
---
graph TB
    %% ============================================================
    %% STYLES
    %% ============================================================
    classDef page fill:#4f46e5,stroke:#3730a3,color:#fff,rx:12
    classDef pageEnterprise fill:#2563eb,stroke:#1d4ed8,color:#fff,rx:12
    classDef pageCoach fill:#7c3aed,stroke:#6d28d9,color:#fff,rx:12
    classDef api fill:#0891b2,stroke:#0e7490,color:#fff,rx:8
    classDef apiOrg fill:#0d9488,stroke:#0f766e,color:#fff,rx:8
    classDef lib fill:#7c3aed,stroke:#6d28d9,color:#fff,rx:8
    classDef data fill:#d97706,stroke:#b45309,color:#fff,rx:8
    classDef ext fill:#dc2626,stroke:#b91c1c,color:#fff,rx:8
    classDef static fill:#059669,stroke:#047857,color:#fff,rx:8
    classDef scenario fill:#ea580c,stroke:#c2410c,color:#fff,rx:8
    classDef context fill:#e11d48,stroke:#be123c,color:#fff,rx:10

    %% ============================================================
    %% UTILISATEURS & RÔLES
    %% ============================================================
    subgraph ROLES["Modèle de Rôles"]
        direction LR
        ROLE_USER["GlobalRole: user\nTous les utilisateurs"]
        ROLE_SADMIN["GlobalRole: super_admin\nAccès admin global"]
        ROLE_MEMBERSHIP["Membership\nOrgRole: admin | member\nLié à une Organization"]
        ROLE_COACH["CoachProfile\nuser.coachProfile.level\napprenti | confirmé"]
    end

    USER((Utilisateur))

    %% ============================================================
    %% ACTIVE CONTEXT
    %% ============================================================
    CONTEXT["ActiveContext\nlocalStorage: active_org_id\npersonal | organizationId\nPropagé → assignments, game_records, APIs"]:::context

    %% ============================================================
    %% PAGES NEXT.JS — GAMEPLAY
    %% ============================================================
    subgraph FRONTEND_GAME["Frontend — Gameplay"]
        direction TB
        HOME["/ — Accueil\nSélection scénarios\nMes espaces org/coach\nFiltres par métier"]:::page
        LOGIN["/login\nConnexion / Inscription\nrole: user par défaut"]:::page
        INTRO["/scenarios/[id]\nAperçu & briefing\nDocuments PDF"]:::page
        PLAY["/scenarios/[id]/play\nInterface de jeu\nChat • Mail • Docs\nPrésentations vocales\n+ organizationId context"]:::page
        DEBRIEF["/scenarios/[id]/debrief\nDébriefing IA\nÉvaluation par phase"]:::page
        PROFILE["/profile\nStatistiques joueur\nCompétences extraites"]:::page
        HISTORY["/history\nHistorique des parties\nExport PDF"]:::page
    end

    %% ============================================================
    %% PAGES NEXT.JS — ADMIN
    %% ============================================================
    subgraph FRONTEND_ADMIN["Frontend — Admin (super_admin)"]
        direction TB
        ADMIN["/admin\nÉditeur scénarios\nVerrouillage\nGestion utilisateurs\nTab Organisations"]:::page
    end

    %% ============================================================
    %% PAGES NEXT.JS — ENTERPRISE
    %% ============================================================
    subgraph FRONTEND_ENTERPRISE["Frontend — Espace Entreprise"]
        direction TB
        ENT_DASH["/enterprise/[orgId]\nTableau de bord\nStats • Actions rapides\nFeature flags"]:::pageEnterprise
        ENT_USERS["/enterprise/[orgId]/users\nGestion utilisateurs\nAjouter membres"]:::pageEnterprise
        ENT_ASSIGN["/enterprise/[orgId]/assign\nAssigner scénarios\nMulti-sélection"]:::pageEnterprise
        ENT_RESULTS["/enterprise/[orgId]/results\nRésultats & stats\nComplétion détaillée"]:::pageEnterprise
        ENT_LAYOUT["layout.tsx\nSidebar enterprise\nactive_org_id context"]:::pageEnterprise
    end

    %% ============================================================
    %% PAGES NEXT.JS — COACH
    %% ============================================================
    subgraph FRONTEND_COACH["Frontend — Espace Coach"]
        direction TB
        COACH_DASH["/coach/[orgId]\nTableau de bord\nProgression coachés\nBarre obligatoire"]:::pageCoach
        COACH_LIST["/coach/[orgId]/coachees\nListe des coachés\nAjouter coachés"]:::pageCoach
        COACH_ASSIGN["/coach/[orgId]/assign\nAssigner parcours\nScénarios → coachés"]:::pageCoach
        COACH_PROGRESS["/coach/[orgId]/progress\nProgression détaillée\nFiltres & cartes"]:::pageCoach
        COACH_LAYOUT["layout.tsx\nSidebar coach\nBadge niveau\nactive_org_id context"]:::pageCoach
    end

    %% ============================================================
    %% API ROUTES — AUTH
    %% ============================================================
    subgraph BACKEND["Backend — API Routes"]
        direction TB

        subgraph AUTH_API["Auth & Session"]
            API_LOGIN["POST /api/auth/login"]:::api
            API_REGISTER["POST /api/auth/register"]:::api
            API_SESSION["GET /api/auth/session"]:::api
            API_USERS["GET /api/auth/users\nsuper_admin only"]:::api
        end

        subgraph SCENARIO_API["Scénarios"]
            API_SCENARIOS["GET /api/scenarios"]:::api
            API_SCENARIO["GET /api/scenarios/[id]"]:::api
            API_PROMPTS["GET /api/scenarios/[id]/prompts/[actor]"]:::api
        end

        subgraph GAME_API["Moteur de jeu"]
            API_CHAT["POST /api/chat\nStreaming NPC"]:::api
            API_EVAL["POST /api/evaluate-presentation"]:::api
            API_DEBRIEF["POST /api/debrief"]:::api
            API_DOWNLOAD["GET /api/download"]:::api
        end

        subgraph PROFILE_API["Profil"]
            API_SAVE_GAME["POST /api/profile/save-game\n+ organizationId\n+ markCompleted()"]:::api
            API_HISTORY["GET /api/profile/history"]:::api
            API_STATS["GET /api/profile/stats"]:::api
            API_PREFS["GET|POST /api/profile/preferences"]:::api
            API_SKILLS["POST /api/profile/extract-skills"]:::api
            API_PDF["GET /api/profile/download-pdf/[id]"]:::api
        end

        subgraph CAPABILITIES_API["Capabilities"]
            API_CAPS["GET /api/capabilities\nMemberships • coachProfile\nbuildCapabilities()"]:::apiOrg
        end

        subgraph ORG_API["Organisations"]
            API_ORGS["GET|POST /api/organizations\nsuper_admin CRUD"]:::apiOrg
            API_ORG["GET|PATCH /api/organizations/[orgId]"]:::apiOrg
            API_MEMBERS["GET|POST /api/organizations/[orgId]/members\nGestion membres"]:::apiOrg
            API_ASSIGNMENTS["GET|POST|DELETE /api/organizations/[orgId]/assignments\n+ ?stats pour analytics"]:::apiOrg
            API_FEATURES["GET|PATCH /api/organizations/[orgId]/features\nFeature flags premium"]:::apiOrg
        end

        subgraph ADMIN_API["Admin"]
            API_CONFIG["GET|POST /api/admin/scenario-config"]:::api
            API_EDITOR["POST /api/admin/scenario-editor"]:::api
            API_SAVE_SC["POST /api/admin/save-scenario"]:::api
        end
    end

    %% ============================================================
    %% LIBRAIRIES INTERNES
    %% ============================================================
    subgraph LIB["Librairies — app/lib/"]
        direction TB

        subgraph LIB_AUTH_GROUP["Auth & Permissions"]
            LIB_AUTH["auth.ts\nSHA-256 • Tokens\nStoredUser → PublicUser\ncoachProfile: CoachProfile\nmigrateRole()\ncreateManagedUser()"]:::lib
            LIB_PERMS["permissions.ts\nGlobalRole: user | super_admin\nOrgRole: admin | member\ncanDo() • buildCapabilities()\nisSuperAdmin() • isAdminRole()"]:::lib
        end

        subgraph LIB_ORG_GROUP["Organisations"]
            LIB_ORGS["organizations.ts\nCRUD Organisation\nMembership management\nType: enterprise | coach"]:::lib
            LIB_ASSIGN["assignments.ts\nassignScenario()\nbatchAssign()\nmarkCompleted()\ngetOrgCompletionStats()"]:::lib
        end

        subgraph LIB_GAME_GROUP["Gameplay"]
            LIB_RUNTIME["runtime.ts\ninitializeSession()\nbuildRuntimeView()\ncompletePhase()"]:::lib
            LIB_TYPES["types.ts\nScenarioDefinition\nSessionState\nPhaseDefinition"]:::lib
            LIB_RECORDS["gameRecords.ts\nServerGameRecord\n+ organizationId field\nSauvegarde par user"]:::lib
        end

        subgraph LIB_OTHER["Autres"]
            LIB_SCENARIOS["scenarios.ts\nloadScenario()\nloadPrompt()\nlistScenarios()"]:::lib
            LIB_PREFS["userPreferences.ts\nFiltres métier"]:::lib
            LIB_CONFIG["scenarioConfig.ts\nadminLocked\nprerequisites"]:::lib
        end
    end

    %% ============================================================
    %% STOCKAGE DONNÉES (JSON)
    %% ============================================================
    subgraph DATA["Stockage — Fichiers JSON"]
        direction TB
        DATA_USERS["data/users.json\n{email, passwordHash,\nrole: GlobalRole,\ncoachProfile?: CoachProfile}"]:::data
        DATA_SESSIONS["data/sessions.json\nTokens • Expiration 7j"]:::data
        DATA_ORGS["data/organizations.json\n{id, name, type,\nmembers: Membership[],\nfeatures: FeatureFlags,\nsettings: {description, logoUrl}}"]:::data
        DATA_ASSIGN["data/assignments.json\n{orgId, scenarioId, userId,\nassignedBy, status,\ncompletedAt?}"]:::data
        DATA_RECORDS["data/game_records/\n{userId}.json\n+ organizationId field"]:::data
        DATA_PREFS["data/user_preferences/\n{userId}.json"]:::data
        DATA_CONFIG["data/scenario_config.json\nVerrouillage scénarios"]:::data
    end

    %% ============================================================
    %% SCÉNARIOS
    %% ============================================================
    subgraph SCENARIOS["Scénarios — scenarios/"]
        direction TB
        SC_JSON["scenario.json\nPhases • Acteurs\nDocuments • Évals"]:::scenario
        SC_PROMPTS["prompts/*.md\nPersonnalité NPC\nConsignes IA"]:::scenario
        SC_RESOURCES["public/scenarios/[id]/\nresources/*.pdf\nimages/*.png"]:::scenario
    end

    %% ============================================================
    %% SERVICES EXTERNES
    %% ============================================================
    subgraph EXTERNAL["Services Externes"]
        direction TB
        OPENAI["OpenAI API\ngpt-4.1-mini\nChat NPC • Éval"]:::ext
        ANTHROPIC["Anthropic API\nClaude\nDébriefing • Éditeur"]:::ext
    end

    %% ============================================================
    %% CONNEXIONS — UTILISATEUR
    %% ============================================================
    USER --> HOME
    USER --> LOGIN
    USER --> CONTEXT
    CONTEXT --> PLAY
    CONTEXT --> ENT_LAYOUT
    CONTEXT --> COACH_LAYOUT

    %% ============================================================
    %% CONNEXIONS — NAVIGATION GAMEPLAY
    %% ============================================================
    HOME --> INTRO
    INTRO --> PLAY
    PLAY --> DEBRIEF
    USER --> PROFILE
    USER --> HISTORY

    %% ============================================================
    %% CONNEXIONS — NAVIGATION ESPACES
    %% ============================================================
    HOME -->|"Mes espaces"| ENT_DASH
    HOME -->|"Mes espaces"| COACH_DASH
    HOME -->|"super_admin"| ADMIN

    ENT_LAYOUT --> ENT_DASH
    ENT_LAYOUT --> ENT_USERS
    ENT_LAYOUT --> ENT_ASSIGN
    ENT_LAYOUT --> ENT_RESULTS

    COACH_LAYOUT --> COACH_DASH
    COACH_LAYOUT --> COACH_LIST
    COACH_LAYOUT --> COACH_ASSIGN
    COACH_LAYOUT --> COACH_PROGRESS

    %% ============================================================
    %% CONNEXIONS — PAGES GAMEPLAY → API
    %% ============================================================
    LOGIN --> API_LOGIN
    LOGIN --> API_REGISTER
    HOME --> API_SCENARIOS
    HOME --> API_CAPS
    INTRO --> API_SCENARIO
    PLAY --> API_CHAT
    PLAY --> API_EVAL
    PLAY --> API_PROMPTS
    PLAY --> API_DOWNLOAD
    DEBRIEF --> API_DEBRIEF
    DEBRIEF --> API_SAVE_GAME
    PROFILE --> API_STATS
    PROFILE --> API_SKILLS
    HISTORY --> API_HISTORY
    HISTORY --> API_PDF

    %% ============================================================
    %% CONNEXIONS — PAGES ENTERPRISE → API
    %% ============================================================
    ENT_DASH --> API_ORG
    ENT_DASH --> API_FEATURES
    ENT_DASH --> API_ASSIGNMENTS
    ENT_USERS --> API_MEMBERS
    ENT_ASSIGN --> API_ASSIGNMENTS
    ENT_ASSIGN --> API_SCENARIOS
    ENT_RESULTS --> API_ASSIGNMENTS

    %% ============================================================
    %% CONNEXIONS — PAGES COACH → API
    %% ============================================================
    COACH_DASH --> API_ORG
    COACH_DASH --> API_ASSIGNMENTS
    COACH_DASH --> API_CAPS
    COACH_LIST --> API_MEMBERS
    COACH_ASSIGN --> API_ASSIGNMENTS
    COACH_ASSIGN --> API_SCENARIOS
    COACH_PROGRESS --> API_ASSIGNMENTS

    %% ============================================================
    %% CONNEXIONS — PAGES ADMIN → API
    %% ============================================================
    ADMIN --> API_CONFIG
    ADMIN --> API_EDITOR
    ADMIN --> API_SAVE_SC
    ADMIN --> API_ORGS
    ADMIN --> API_USERS

    %% ============================================================
    %% CONNEXIONS — API → LIB
    %% ============================================================
    API_LOGIN --> LIB_AUTH
    API_REGISTER --> LIB_AUTH
    API_SESSION --> LIB_AUTH
    API_USERS --> LIB_AUTH
    API_CAPS --> LIB_PERMS
    API_CAPS --> LIB_AUTH
    API_CAPS --> LIB_ORGS

    API_SCENARIOS --> LIB_SCENARIOS
    API_SCENARIO --> LIB_SCENARIOS
    API_PROMPTS --> LIB_SCENARIOS

    API_CHAT --> LIB_RUNTIME
    API_SAVE_GAME --> LIB_RECORDS
    API_SAVE_GAME --> LIB_ASSIGN
    API_HISTORY --> LIB_RECORDS
    API_STATS --> LIB_RECORDS

    API_ORGS --> LIB_ORGS
    API_ORG --> LIB_ORGS
    API_MEMBERS --> LIB_ORGS
    API_MEMBERS --> LIB_AUTH
    API_ASSIGNMENTS --> LIB_ASSIGN
    API_FEATURES --> LIB_ORGS

    API_PREFS --> LIB_PREFS
    API_CONFIG --> LIB_CONFIG

    %% ============================================================
    %% CONNEXIONS — LIB → DATA
    %% ============================================================
    LIB_AUTH --> DATA_USERS
    LIB_AUTH --> DATA_SESSIONS
    LIB_ORGS --> DATA_ORGS
    LIB_ASSIGN --> DATA_ASSIGN
    LIB_RECORDS --> DATA_RECORDS
    LIB_PREFS --> DATA_PREFS
    LIB_CONFIG --> DATA_CONFIG
    LIB_SCENARIOS --> SCENARIOS

    %% ============================================================
    %% CONNEXIONS — API → SERVICES EXTERNES
    %% ============================================================
    API_CHAT --> OPENAI
    API_EVAL --> OPENAI
    API_DEBRIEF --> ANTHROPIC
    API_EDITOR --> ANTHROPIC
    API_SKILLS --> OPENAI

    %% ============================================================
    %% CONNEXIONS — ASSETS
    %% ============================================================
    API_DOWNLOAD --> SC_RESOURCES
    INTRO --> SC_RESOURCES
    PLAY --> SC_RESOURCES
